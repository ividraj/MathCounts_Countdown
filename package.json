{
  "name": "mathcounts-ladder",
  "version": "1.0.0",
  "private": true,
  "description": "MathCounts-style ladder tournament tracker",
  "main": "main.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "electron .",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.mathcounts.ladder",
    "productName": "MathCounts Ladder",
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "main.js",
      "tournament-engine.js",
      "README.md"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^25.1.8"
  }
}
